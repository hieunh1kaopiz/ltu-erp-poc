{
    "name": "ltu/erp-poc",
    "description": "LTU ERP simulation app for centralized deployment POC",
    "type": "project",
    "require": {
        "php": ">=7.2.5",
        "vlucas/phpdotenv": "^5.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
